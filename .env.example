APP_NAME="Docuwisev1"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Manila
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- MySQL (works out-of-the-box with XAMPP/Laragon + phpMyAdmin) ---
# Create a database matching DB_DATABASE first, then fill in your own
# credentials below — these are placeholders, not real values.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=docuwise
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=reverb

# --- Email (see README "Continuous operation" §2.6) ---
# 'log' writes emails to storage/logs/laravel.log instead of sending them —
# works out of the box for a demo/dev setup, no account needed. Replace with
# real smtp+MAIL_HOST/PORT/USERNAME/PASSWORD credentials for production.
MAIL_MAILER=log

FILESYSTEM_DISK=local

# --- Backups (see README "Continuous operation" §2.4) ---
BACKUP_KEEP=14

# --- Reverb WebSocket server, for live dashboard/notification push
# (README §2.5) — run `php artisan reverb:install` to generate real
# per-installation values for the four below; these are placeholders. ---
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# OCR + PDF extraction packages (smalot/pdfparser, thiagoalessio/tesseract_ocr)
# are already required in composer.json — `composer install` gets them.
# The system tesseract-ocr binary they shell out to for scanned-image OCR is
# either installed normally (apt/Windows) or falls back automatically to the
# bundled copy at storage/tesseract-bin — see README §2.3.
