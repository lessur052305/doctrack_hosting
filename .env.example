APP_NAME="Docuwisev1"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Manila
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- MySQL (works out-of-the-box with XAMPP/Laragon + phpMyAdmin) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=docuwise
DB_USERNAME=lessur
DB_PASSWORD=010622

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=database

FILESYSTEM_DISK=local

# --- Optional: OCR + PDF extraction (see README "Full-fidelity extras") ---
# Install: composer require smalot/pdfparser thiagoalessio/tesseract_ocr
# System:  apt install tesseract-ocr   (or the Windows installer)
