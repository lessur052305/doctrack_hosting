{
    "name": "ujfcorp/doctrack",
    "type": "project",
    "description": "Automated Document Classification and Tracking System for Company Records Management Using Machine Learning (Laravel).",
    "keywords": ["laravel", "document-management", "machine-learning", "capstone"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "laravel/tinker": "^2.9",
        "php-ai/php-ml": "^0.10.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0"
    },
    "_comment_svm": "php-ai/php-ml provides the SVM (SVC) + TF-IDF classifier used by App\\Services\\ClassificationService, matching the thesis. It uses php-ml's bundled libsvm (no PECL svm extension needed).",
    "_comment_optional_packages": "For full-fidelity hybrid text extraction (Scope 1.4), additionally run: composer require smalot/pdfparser thiagoalessio/tesseract_ocr (plus system tesseract-ocr). TextExtractionService degrades gracefully without them.",
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "policy": {
            "advisories": {
                "block": false
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
