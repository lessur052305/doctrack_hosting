[Unit]
Description=DocuWise (docuwisev1) persistent queue worker — required for real-time EscalateAssignmentJob delivery
After=network.target

[Service]
Type=simple
WorkingDirectory=__PROJECT_PATH__
ExecStart=__PHP_BINARY__ artisan queue:work --sleep=1 --tries=3 --max-time=3600
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
