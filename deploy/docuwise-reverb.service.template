[Unit]
Description=DocuWise (docuwisev1) Reverb WebSocket server — required for real-time dashboard/notification push
After=network.target

[Service]
Type=simple
WorkingDirectory=__PROJECT_PATH__
ExecStart=__PHP_BINARY__ artisan reverb:start --host=0.0.0.0 --port=8080
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
